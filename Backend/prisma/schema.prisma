generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Tenant {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  joinCode    String       @unique
  trips       Trip[]
  userTenants UserTenant[]
}

model User {
  id                     Int               @id @default(autoincrement())
  email                  String            @unique
  description            String?
  createdDate            DateTime          @default(now())
  latestData             DateTime?
  firebaseUid            String            @unique
  name                   String
  disabledAt             DateTime?
  isDisabled             Boolean           @default(false)
  attendanceEvents       AttendanceEvent[] @relation("AttendanceEventActor")
  buses                  Bus[]             @relation("BusManager")
  adminApprovedRounds    BusRoundStatus[]  @relation("AdminApprovedBy")
  driverConfirmedRounds  BusRoundStatus[]  @relation("DriverConfirmedBy")
  notifications          Notification[]
  approvedUnlockRequests UnlockRequest[]   @relation("UnlockRequestApprover")
  createdUnlockRequests  UnlockRequest[]   @relation("UnlockRequestCreator")
  userTenants            UserTenant[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  userTenants UserTenant[]
}

model UserTenant {
  id       Int     @id @default(autoincrement())
  userId   Int
  tenantId Int?
  roleId   Int
  role     Role    @relation(fields: [roleId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([roleId])
}

model Trip {
  id       Int     @id @default(autoincrement())
  name     String
  status   Status
  tenantId Int
  buses    Bus[]
  rounds   Round[]
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Bus {
  id                 Int               @id @default(autoincrement())
  registrationNumber String
  busCode            String
  driverName         String?
  driverTel          String?
  tourGuideName      String?
  tourGuideTel       String?
  description        String?
  managerId          Int
  tripId             Int
  attendanceEvents   AttendanceEvent[] @relation("AttendanceEventBus")
  manager            User              @relation("BusManager", fields: [managerId], references: [id])
  trip               Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  busRoundStatuses   BusRoundStatus[]
  passengers         Passenger[]
  transactions       Transaction[]
  unlockRequests     UnlockRequest[]

  @@unique([tripId, busCode])
  @@index([managerId])
  @@index([tripId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  content   String
  payload   Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Round {
  id               Int              @id @default(autoincrement())
  name             String
  time             String
  status           Status
  tripId           Int
  busRoundStatuses BusRoundStatus[]
  trip             Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  unlockRequests   UnlockRequest[]

  @@index([tripId])
}

model Passenger {
  id           Int           @id @default(autoincrement())
  name         String
  note         String?
  busId        Int
  tel          String        @default("")
  bus          Bus           @relation(fields: [busId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([busId])
}

model Transaction {
  id           Int               @id @default(autoincrement())
  busId        Int
  roundId      Int
  passengerId  Int
  checkIn      Boolean           @default(false)
  checkOut     Boolean           @default(false)
  lastActionAt DateTime?
  checkInNote  String?
  checkOutNote String?
  events       AttendanceEvent[]
  bus          Bus               @relation(fields: [busId], references: [id], onDelete: Cascade)
  passenger    Passenger         @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  round        Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([passengerId, roundId])
  @@index([busId])
  @@index([roundId])
  @@index([passengerId])
}

model AttendanceEvent {
  id            Int              @id @default(autoincrement())
  transactionId Int
  action        AttendanceAction
  actorId       Int?
  busId         Int
  note          String?
  createdAt     DateTime         @default(now())
  actor         User?            @relation("AttendanceEventActor", fields: [actorId], references: [id])
  bus           Bus              @relation("AttendanceEventBus", fields: [busId], references: [id])
  transaction   Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([actorId])
  @@index([busId])
  @@index([createdAt])
}

model BusRoundStatus {
  id                Int       @id @default(autoincrement())
  busId             Int
  roundId           Int
  checkInLocked     Boolean   @default(false)
  checkInAt         DateTime?
  checkOutLocked    Boolean   @default(false)
  checkOutAt        DateTime?
  adminApprovedBy   Int?
  driverConfirmedBy Int?
  adminApprover     User?     @relation("AdminApprovedBy", fields: [adminApprovedBy], references: [id])
  bus               Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  driverConfirmer   User?     @relation("DriverConfirmedBy", fields: [driverConfirmedBy], references: [id])
  round             Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([busId, roundId])
}

model UnlockRequest {
  id           Int           @id @default(autoincrement())
  busId        Int
  roundId      Int
  type         String        @default("check_in")
  reason       String?
  status       RequestStatus @default(PENDING)
  requestedBy  Int
  createdAt    DateTime      @default(now())
  respondedAt  DateTime?
  handledBy    Int?
  rejectReason String?
  bus          Bus           @relation(fields: [busId], references: [id], onDelete: Cascade)
  handler      User?         @relation("UnlockRequestApprover", fields: [handledBy], references: [id])
  requester    User          @relation("UnlockRequestCreator", fields: [requestedBy], references: [id])
  round        Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([busId, roundId, type])
  @@index([busId])
  @@index([roundId])
  @@index([status])
}

enum Status {
  DOING
  DONE
}

enum BusRoundCompletionStatus {
  PENDING
  DRIVER_CONFIRMED
  ADMIN_APPROVED
}

enum AttendanceAction {
  CHECK_IN_ON
  CHECK_IN_OFF
  CHECK_OUT_ON
  CHECK_OUT_OFF
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
