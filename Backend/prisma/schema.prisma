generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  joinCode    String       @unique
  trips       Trip[]
  userTenants UserTenant[]
}

model User {
  id                     Int             @id @default(autoincrement())
  email                  String          @unique
  description            String?
  createdDate            DateTime        @default(now())
  latestData             DateTime?
  firebaseUid            String          @unique
  name                   String
  buses                  Bus[]           @relation("BusManager")
  checkInActions         Transaction[]   @relation("CheckInUser")
  checkOutActions        Transaction[]   @relation("CheckOutUser")
  approvedUnlockRequests UnlockRequest[] @relation("UnlockRequestApprover")
  createdUnlockRequests  UnlockRequest[] @relation("UnlockRequestCreator")
  userTenants            UserTenant[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  userTenants UserTenant[]
}

model UserTenant {
  id       Int     @id @default(autoincrement())
  userId   Int
  tenantId Int?
  roleId   Int
  role     Role    @relation(fields: [roleId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([roleId])
}

model Trip {
  id       Int     @id @default(autoincrement())
  name     String
  status   Status
  tenantId Int
  buses    Bus[]
  rounds   Round[]
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Bus {
  id                 Int              @id @default(autoincrement())
  registrationNumber String
  busCode            String
  driverName         String?
  driverTel          String?
  tourGuideName      String?
  tourGuideTel       String?
  description        String?
  managerId          Int
  tripId             Int
  manager            User             @relation("BusManager", fields: [managerId], references: [id])
  trip               Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  busRoundStatuses   BusRoundStatus[]
  passengers         Passenger[]
  transactions       Transaction[]
  unlockRequests     UnlockRequest[]

  @@unique([tripId, busCode])
  @@index([managerId])
  @@index([tripId])
}

model Round {
  id               Int              @id @default(autoincrement())
  name             String
  time             String
  status           Status
  tripId           Int
  busRoundStatuses BusRoundStatus[]
  trip             Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  unlockRequests   UnlockRequest[]

  @@index([tripId])
}

model Passenger {
  id           Int           @id @default(autoincrement())
  name         String
  note         String?
  busId        Int
  tel          String        @default("")
  bus          Bus           @relation(fields: [busId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([busId])
}

model Transaction {
  id           Int       @id @default(autoincrement())
  busId        Int
  roundId      Int
  passengerId  Int
  checkIn      Boolean   @default(false)
  checkOut     Boolean   @default(false)
  note         String?
  checkInAt    DateTime?
  checkInBy    Int?
  checkOutAt   DateTime?
  checkOutBy   Int?
  bus          Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  checkInUser  User?     @relation("CheckInUser", fields: [checkInBy], references: [id])
  checkOutUser User?     @relation("CheckOutUser", fields: [checkOutBy], references: [id])
  passenger    Passenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  round        Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([passengerId, roundId])
  @@index([busId])
  @@index([roundId])
  @@index([passengerId])
}

model BusRoundStatus {
  id             Int       @id @default(autoincrement())
  busId          Int
  roundId        Int
  checkInLocked  Boolean   @default(false)
  checkInAt      DateTime?
  checkOutLocked Boolean   @default(false)
  checkOutAt     DateTime?
  bus            Bus       @relation(fields: [busId], references: [id])
  round          Round     @relation(fields: [roundId], references: [id])

  @@unique([busId, roundId])
}

model UnlockRequest {
  id          Int           @id @default(autoincrement())
  busId       Int
  roundId     Int
  type        String        @default("check_in")
  reason      String?
  status      RequestStatus @default(PENDING)
  requestedBy Int
  approvedBy  Int?
  createdAt   DateTime      @default(now())
  respondedAt DateTime?
  approver    User?         @relation("UnlockRequestApprover", fields: [approvedBy], references: [id])
  bus         Bus           @relation(fields: [busId], references: [id], onDelete: Cascade)
  requester   User          @relation("UnlockRequestCreator", fields: [requestedBy], references: [id])
  round       Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([busId, roundId, type])
  @@index([busId])
  @@index([roundId])
  @@index([status])
}

enum Status {
  DOING
  DONE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
